# ─────────────────────────────────────────────────────────
# Next Generation Esports — Environment Variables
# Copy this file to .env and fill in values as needed.
# ─────────────────────────────────────────────────────────

# Dev server port (default: 5173)
# PORT=5173

# Base path for GitHub Pages deployment.
# Set to your repo name, e.g. /ng-esports/
# Leave empty or omit for local dev (defaults to /)
# VITE_BASE_PATH=/ng-esports/
